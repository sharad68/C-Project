{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Cors": {
    "AllowedOrigins": ["http://localhost:5173"]
  },
  "Jwt": {
    "Issuer": "Tornois.Api",
    "Audience": "Tornois.Frontend",
    "SigningKey": "dev-only-replace-with-env-secret-1234567890",
    "ExpirationMinutes": 480
  },
  "ConnectionStrings": {
    "Postgres": "Host=localhost;Port=5433;Database=tornois;Username=tornois;Password=tornois_dev_password"
  },
  "SyncJobs": {
    "Enabled": true,
    "DailyApiQuota": 500,
    "LiveScoresCron": "0 0/5 * * * ?",
    "FixturesCron": "0 0 3 * * ?",
    "EnrichmentCron": "0 0 2 ? * SUN"
  },
  "ExternalApis": {
    "ApiSportsBaseUrl": "https://v3.football.api-sports.io",
    "TheSportsDbBaseUrl": "https://www.thesportsdb.com/api/v1/json",
    "ApiSportsApiKey": "",
    "TheSportsDbApiKey": ""
  }
}
